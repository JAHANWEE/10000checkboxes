# Server
PORT=3000

# Redis / Valkey connection URL
# Local Docker:  redis://localhost:6379
# Render Redis:  redis://red-xxxx:6379  (internal)
#                rediss://red-xxxx:6379 (external / TLS)
REDIS_URL=redis://localhost:6379

# Checkbox grid size (default: 10000)
TOTAL_CHECKBOXES=10000

# Redis pub/sub channel name
PUB_CHAN=cb:updates

# WebSocket rate limiting
# Max toggle events allowed per socket per window
WS_TOGGLE_LIMIT=20
WS_TOGGLE_WINDOW=5
